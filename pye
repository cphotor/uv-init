#!/bin/bash

# pye: Configure development environment for Python projects with Windsurf/VS Code settings
VERSION="1.1.8"

PROJECT_DIR="."
LINE_LENGTH=88  # Default to PEP 8

# Detect language environment
detect_language() {
    if [[ "$LANG" =~ zh_CN ]] || [[ "$LANG" =~ zh_TW ]] || [[ "$LC_ALL" =~ zh ]] || [[ "$LANGUAGE" =~ zh ]]; then
        echo "zh"
    else
        echo "en"
    fi
}

LANG_ENV=$(detect_language)

# Show usage information
show_usage() {
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "用法：pye [选项] [项目目录]"
        echo "选项:"
        echo "  --pep8                  设置代码行长度限制为 88（PEP 8 标准，默认）"
        echo "  --github                设置代码行长度限制为 100（GitHub 标准）"
        echo "  --wide                  设置代码行长度限制为 120（宽屏模式）"
        echo "  -H, --help              显示帮助信息"
        echo "  -V, --version           显示版本信息"
        echo "  项目目录   目标目录（默认：当前目录）"
    else
        echo "Usage: pye [options] [project-directory]"
        echo "Options:"
        echo "  --pep8                  Set code line length limit to 88 (PEP 8 standard, default)"
        echo "  --github                Set code line length limit to 100 (GitHub standard)"
        echo "  --wide                  Set code line length limit to 120 (wide screen mode)"
        echo "  -H, --help              Show help message"
        echo "  -V, --version           Show version information"
        echo "  project-directory   Target directory (default: current directory)"
    fi
    exit 0
}

# Show version information
show_version() {
    echo "pye version $VERSION"
    exit 0
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --help|-H)
            show_usage
            ;;
        --version|-V)
            show_version
            ;;
        --pep8)
            LINE_LENGTH=88
            shift
            ;;
        --github)
            LINE_LENGTH=100
            shift
            ;;
        --wide)
            LINE_LENGTH=120
            shift
            ;;
        -*)
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "未知选项：$1"
            else
                echo "Unknown option: $1"
            fi
            show_usage
            ;;
        *)
            PROJECT_DIR="$1"
            shift
            ;;
    esac
done

# Validate project directory
if [ ! -d "$PROJECT_DIR" ]; then
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "错误：目录 '$PROJECT_DIR' 不存在。"
        echo "请先创建项目：uv init [项目名] 或 python -m venv .venv"
    else
        echo "Error: Directory '$PROJECT_DIR' does not exist."
        echo "Please create the project first with: uv init [project-name] or python -m venv .venv"
    fi
    exit 1
fi

# Get project display name from directory
if [[ "$PROJECT_DIR" == "." ]]; then
    # If using current directory, try to get the actual folder name
    PROJECT_DISPLAY_NAME=$(basename "$(pwd)")
else
    PROJECT_DISPLAY_NAME=$(basename "$PROJECT_DIR")
fi

# Change to project directory
cd "$PROJECT_DIR"

# Extract Python version from uv project
if [ -f "pyproject.toml" ]; then
    # Try to read Python version from pyproject.toml requires-python field
    PYTHON_VERSION=$(grep -E 'requires-python\s*=\s*"[^"]*"' pyproject.toml | sed -E 's/.*>=([0-9\.]+).*/\1/' | head -1)
    
    # If not found in requires-python, try to extract from .python-version file
    if [ -z "$PYTHON_VERSION" ] && [ -f ".python-version" ]; then
        PYTHON_VERSION=$(cat .python-version)
    fi
    
    # If still not found, try to get from uv python list (active version)
    if [ -z "$PYTHON_VERSION" ] && command -v uv &> /dev/null; then
        PYTHON_VERSION=$(uv python list 2>/dev/null | grep '\*' | awk '{print $2}' | head -1)
    fi
    
    # Default to 3.13 if still not found
    if [ -z "$PYTHON_VERSION" ]; then
        PYTHON_VERSION="3.13"
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "警告: 无法检测 Python 版本，使用默认版本 3.13"
        else
            echo "Warning: Could not detect Python version, using default 3.13"
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "检测到 Python 版本: $PYTHON_VERSION"
        else
            echo "Detected Python version: $PYTHON_VERSION"
        fi
    fi
else
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "错误: 未找到 pyproject.toml。请在 Python 项目目录中运行此脚本。"
    else
        echo "Error: pyproject.toml not found. Please run this in a Python project directory."
    fi
    exit 1
fi

# Set version variables
PY_VERSION="$PYTHON_VERSION"
TARGET_VERSION="py${PYTHON_VERSION//./}"

# Create .vscode directory
mkdir -p .vscode

# Create/update settings.json
if [ -f ".vscode/settings.json" ]; then
    # Check if editor.defaultFormatter exists
    if grep -q "editor.defaultFormatter" .vscode/settings.json; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   ✓ VS Code 格式化配置已存在，跳过..."
        else
            echo "   ✓ VS Code formatting configuration already exists, skipped..."
        fi
        
        # Still add auto-save settings if not present
        if ! grep -q "files.autoSave" .vscode/settings.json; then
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   → 正在添加自动延时保存配置..."
            else
                echo "   → Adding auto-delay save configuration..."
            fi
            if ! jq '. + {
                "files.autoSave": "afterDelay",
                "files.autoSaveDelay": 1000
            }' .vscode/settings.json > .vscode/settings.json.tmp 2>/dev/null; then
                if [[ "$LANG_ENV" == "zh" ]]; then
                    echo "   ⚠️ 警告：更新 settings.json 失败，跳过..."
                else
                    echo "   ⚠️ Warning: Failed to update settings.json, skipping..."
                fi
                rm -f .vscode/settings.json.tmp
            else
                mv .vscode/settings.json.tmp .vscode/settings.json
            fi
        else
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   ✓ 自动延时保存配置已存在，跳过..."
            else
                echo "   ✓ Auto-delay save configuration already exists, skipped..."
            fi
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 正在添加 VS Code 格式化配置..."
        else
            echo "   → Adding VS Code formatting configuration..."
        fi
        # Create temp file with new settings and merge
        if ! jq '. + {
            "[python]": {
                "editor.defaultFormatter": "charliermarsh.ruff",
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.organizeImports.ruff": "explicit",
                    "source.fixAll.ruff": "explicit"
                }
            },
            "files.autoSave": "afterDelay",
            "files.autoSaveDelay": 1000
        }' .vscode/settings.json > .vscode/settings.json.tmp 2>/dev/null; then
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   ⚠️ 警告：更新 settings.json 失败，跳过..."
            else
                echo "   ⚠️ Warning: Failed to update settings.json, skipping..."
            fi
            rm -f .vscode/settings.json.tmp
        else
            mv .vscode/settings.json.tmp .vscode/settings.json
        fi
    fi
else
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "   ✓ 创建 .vscode/settings.json..."
    else
        echo "   ✓ Creating .vscode/settings.json..."
    fi
    cat > .vscode/settings.json << 'VSCODEEOF'
{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.ruff": "explicit",
            "source.fixAll.ruff": "explicit"
        }
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000
}
VSCODEEOF
fi

# Create/update extensions.json for recommended extensions
if [ -f ".vscode/extensions.json" ]; then
    # Check if recommendations already exist and match
    if jq -e '.recommendations | index("charliermarsh.ruff")' .vscode/extensions.json > /dev/null 2>&1 && \
       jq -e '.recommendations | index("ms-python.python")' .vscode/extensions.json > /dev/null 2>&1; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   ✓ VS Code 扩展推荐配置已存在，跳过..."
        else
            echo "   ✓ VS Code extensions recommendation already exists, skipped..."
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 正在更新 .vscode/extensions.json..."
        else
            echo "   → Updating .vscode/extensions.json..."
        fi
        # Ensure recommended extensions include our suggestions
        if ! jq '{
            recommendations: [
                "ms-python.python",
                "charliermarsh.ruff"
            ]
        }' .vscode/extensions.json > .vscode/extensions.json.tmp 2>/dev/null; then
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   ⚠️ 警告：更新 extensions.json 失败，跳过..."
            else
                echo "   ⚠️ Warning: Failed to update extensions.json, skipping..."
            fi
            rm -f .vscode/extensions.json.tmp
        else
            mv .vscode/extensions.json.tmp .vscode/extensions.json
        fi
    fi
else
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "   ✓ 创建 .vscode/extensions.json..."
    else
        echo "   ✓ Creating .vscode/extensions.json..."
    fi
    cat > .vscode/extensions.json << 'EXTENSIONSEOF'
{
    "recommendations": [
        "ms-python.python",
        "charliermarsh.ruff"
    ]
}
EXTENSIONSEOF
fi

# Create/update pyrightconfig.json
if [ -f "pyrightconfig.json" ]; then
    # Check if pythonVersion matches current version
    CURRENT_VERSION=$(jq -r '.pythonVersion // empty' pyrightconfig.json 2>/dev/null)
    if [ "$CURRENT_VERSION" = "$PY_VERSION" ]; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   ✓ Pyright 配置已存在，跳过..."
        else
            echo "   ✓ Pyright configuration already exists, skipped..."
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 正在更新 pyrightconfig.json (Python $PY_VERSION)..."
        else
            echo "   → Updating pyrightconfig.json (Python $PY_VERSION)..."
        fi
        # Update pythonVersion and other key settings
        if ! jq --arg py_version "$PY_VERSION" '{
            pythonVersion: $py_version,
            typeCheckingMode: "standard",
            reportMissingImports: false,
            reportUndefinedVariable: false,
            reportMissingTypeStubs: true,
            reportGeneralTypeIssues: true
        }' pyrightconfig.json > pyrightconfig.json.tmp 2>/dev/null; then
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   ⚠️ 警告：更新 pyrightconfig.json 失败，跳过..."
            else
                echo "   ⚠️ Warning: Failed to update pyrightconfig.json, skipping..."
            fi
            rm -f pyrightconfig.json.tmp
        else
            mv pyrightconfig.json.tmp pyrightconfig.json
        fi
    fi
else
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "   ✓ 创建 pyrightconfig.json..."
    else
        echo "   ✓ Creating pyrightconfig.json..."
    fi
    cat > pyrightconfig.json << PYRIGHTEOF
{
  "pythonVersion": "$PY_VERSION",
  "typeCheckingMode": "standard",
  "reportMissingImports": false,
  "reportUndefinedVariable": false,
  "reportMissingTypeStubs": true,
  "reportGeneralTypeIssues": true
}
PYRIGHTEOF
fi

# Create/update .gitignore with recommended entries

# Initialize gitignore_content with essential entries
GITIGNORE_CONTENT=""

# Add .ruff_cache to gitignore
GITIGNORE_CONTENT+=".ruff_cache
"

# Add VS Code user-specific files (not the entire directory)
GITIGNORE_CONTENT+="
# VS Code user-specific files
.vscode/settings.json.user
.vscode/workspace.xml
.vscode/*.lock
"

# Add common Python development ignores
GITIGNORE_CONTENT+="
# Python development
__pycache__/
*.py[cod]
*\$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.pyc
*.pyo
*.pyd
*~
"

# Add uv/pip/poetry specific ignores
GITIGNORE_CONTENT+="
# Virtual environments
.venv/
venv/
ENV/
env/
.env/
"

# Check if .gitignore exists
if [ -f ".gitignore" ]; then
    # Check if all required entries exist
    MISSING_ENTRIES=()
    while IFS= read -r line; do
        # Skip empty lines and comments
        if [[ -z "$line" ]] || [[ "$line" =~ ^#.* ]]; then
            continue
        fi
        
        # Check if this line already exists in .gitignore
        if ! grep -qxF "$line" .gitignore; then
            MISSING_ENTRIES+=("$line")
        fi
    done <<< "$GITIGNORE_CONTENT"
    
    if [ ${#MISSING_ENTRIES[@]} -eq 0 ]; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   ✓ .gitignore 配置已存在，跳过..."
        else
            echo "   ✓ .gitignore configuration already exists, skipped..."
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 正在更新 .gitignore..."
        else
            echo "   → Updating .gitignore..."
        fi
        # Add missing entries
        for entry in "${MISSING_ENTRIES[@]}"; do
            echo "$entry" >> .gitignore
        done
    fi
else
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "   ✓ 创建 .gitignore..."
    else
        echo "   ✓ Creating .gitignore..."
    fi
    echo "$GITIGNORE_CONTENT" > .gitignore
fi

# Update configurations in pyproject.toml
if [ -f pyproject.toml ]; then
    # Track if any changes were made to pyproject.toml
    PYPROJECT_CHANGED=false
    
    # Update [tool.ruff] section
    if grep -q "^\[tool.ruff\]" pyproject.toml; then
        # Check if ruff config needs update by comparing key values
        CURRENT_LINE_LENGTH=$(grep -A 5 '^\[tool\.ruff\]' pyproject.toml | grep 'line-length' | sed 's/.*=\s*//' | tr -d '"' | xargs)
        CURRENT_TARGET_VERSION=$(grep -A 5 '^\[tool\.ruff\]' pyproject.toml | grep 'target-version' | sed 's/.*=\s*//' | tr -d '"' | xargs)
        
        if [ "$CURRENT_LINE_LENGTH" = "$LINE_LENGTH" ] && [ "$CURRENT_TARGET_VERSION" = "$TARGET_VERSION" ]; then
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   ✓ Ruff 配置已存在，跳过..."
            else
                echo "   ✓ Ruff configuration already exists, skipped..."
            fi
        else
            if [[ "$LANG_ENV" == "zh" ]]; then
                echo "   → 正在更新 [tool.ruff] 配置 (line-length: $LINE_LENGTH, target-version: $TARGET_VERSION)..."
            else
                echo "   → Updating [tool.ruff] configuration (line-length: $LINE_LENGTH, target-version: $TARGET_VERSION)..."
            fi
            
            # Create temporary file with updated ruff config - remove all ruff sections first
            awk '
            BEGIN { in_ruff_section = 0 }
            /^\[tool\.ruff/ { 
                in_ruff_section = 1
                next
            }
            /^\[tool\./ && in_ruff_section {
                in_ruff_section = 0
                print $0
                next
            }
            END {
                if (in_ruff_section == 0) {
                    print ""
                    print "[tool.ruff]"
                    print "line-length = '"${LINE_LENGTH}"'"
                    print "target-version = \"'"${TARGET_VERSION}"'\""
                    print ""
                    print "[tool.ruff.lint]"
                    print "select = ["
                    print "  \"E\", \"W\", \"F\", \"I\", \"N\", \"UP\", \"B\", \"A\", \"C4\", \"T20\", \"SIM\", \"ARG\", \"PTH\""
                    print "]"
                    print "fixable = [\"ALL\"]"
                    print "ignore = [\"E501\", \"T20\"]"
                    print ""
                    print "[tool.ruff.format]"
                    print "quote-style = \"double\""
                    print "indent-style = \"space\""
                } else {
                    print ""
                    print "[tool.ruff]"
                    print "line-length = '"${LINE_LENGTH}"'"
                    print "target-version = \"'"${TARGET_VERSION}"'\""
                    print ""
                    print "[tool.ruff.lint]"
                    print "select = ["
                    print "  \"E\", \"W\", \"F\", \"I\", \"N\", \"UP\", \"B\", \"A\", \"C4\", \"T20\", \"SIM\", \"ARG\", \"PTH\""
                    print "]"
                    print "fixable = [\"ALL\"]"
                    print "ignore = [\"E501\", \"T20\"]"
                    print ""
                    print "[tool.ruff.format]"
                    print "quote-style = \"double\""
                    print "indent-style = \"space\""
                }
            }
            !in_ruff_section { print }
            ' pyproject.toml > pyproject.toml.tmp && mv pyproject.toml.tmp pyproject.toml
            PYPROJECT_CHANGED=true
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 添加 [tool.ruff] 配置..."
        else
            echo "   → Adding [tool.ruff] configuration..."
        fi
        cat >> pyproject.toml << RUFFEOF

[tool.ruff]
line-length = ${LINE_LENGTH}
target-version = "$TARGET_VERSION"

[tool.ruff.lint]
select = [
  "E", "W", "F", "I", "N", "UP", "B", "A", "C4", "T20", "SIM", "ARG", "PTH"
]
fixable = ["ALL"]
ignore = ["E501", "T20"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
RUFFEOF
        PYPROJECT_CHANGED=true
    fi
    
    # Update [tool.vscode] section
    if grep -q "^\[tool.vscode\]" pyproject.toml; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   ✓ VSCode 环境配置已存在，跳过..."
        else
            echo "   ✓ VSCode environment configuration already exists, skipped..."
        fi
    else
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "   → 添加 [tool.vscode] 配置..."
        else
            echo "   → Adding [tool.vscode] configuration..."
        fi
        cat >> pyproject.toml << VSCODEEOF

# VS Code/Windsurf Python environment configuration
[tool.vscode]
python.terminal.activateEnvironment = true
python.workspaceSearchPaths = ["./**/.venv"]
python.terminal.autoActivationType = "shellStartup"
VSCODEEOF
        PYPROJECT_CHANGED=true
    fi
fi

# Check and handle virtual environment
if [ -d ".venv" ]; then
    VENV_EXISTS=true
else
    VENV_EXISTS=false
    # Check if uv is available
    if ! command -v uv &> /dev/null; then
        if [[ "$LANG_ENV" == "zh" ]]; then
            echo "❌ 未找到 uv 命令。请先安装 uv: https://docs.astral.sh/uv/getting-started/installation/"
            echo "   macOS: curl -LsSf https://astral.sh/uv/install.sh | sh"
            echo "   或使用：brew install uv"
        else
            echo "❌ uv command not found. Please install uv first: https://docs.astral.sh/uv/getting-started/installation/"
            echo "   macOS: curl -LsSf https://astral.sh/uv/install.sh | sh"
            echo "   Or use: brew install uv"
        fi
        exit 1
    fi
    
    # Create virtual environment
    if [[ "$LANG_ENV" == "zh" ]]; then
        echo "   ✓ 创建虚拟环境..."
        # Run uv venv and translate output to Chinese
        uv venv 2>&1 | while IFS= read -r line; do
            if [[ "$line" =~ ^Using ]]; then
                echo "   使用 CPython $(echo "$line" | sed 's/Using CPython //')"
            elif [[ "$line" =~ ^Creating ]]; then
                echo "   正在创建虚拟环境：$(echo "$line" | sed 's/Creating virtual environment at: //')"
            elif [[ "$line" =~ ^Activate ]]; then
                # Skip activate message as it's not needed for uv projects
                continue
            else
                echo "   $line"
            fi
        done
    else
        echo "   ✓ Creating virtual environment..."
        uv venv 2>&1 | grep -v "^Activate"
    fi
fi

if [[ "$LANG_ENV" == "zh" ]]; then
    echo "✅ 已为 \"$PROJECT_DISPLAY_NAME\" 项目配置/更新开发环境！"
    echo ""
    echo "   已检查并按需更新配置:"
    echo "   - pyproject.toml 中的 Ruff 配置"
    echo "   - Pyright 配置" 
    echo "   - VS Code/Windsurf 设置"
    echo "   - 已配置推荐扩展"
    if [ "$VENV_EXISTS" = true ]; then
        echo "   - 虚拟环境已存在"
    else
        echo "   - 已创建虚拟环境"
    fi
    echo ""
    echo "💡 提示："
    echo "   - 现在可以开始编码了！"
    echo '   - 使用 "uv run <script.py>" 运行 Python 脚本'
    echo '   - 需要时执行 "uv add <package-name>" 添加依赖（如：uv add requests）'
else
    echo "✅ Development environment configured/updated for \"$PROJECT_DISPLAY_NAME\" project!"
    echo ""
    echo "   Checked and updated configurations:"
    echo "   - Ruff configuration in pyproject.toml"
    echo "   - Pyright configuration" 
    echo "   - VS Code/Windsurf settings"
    echo "   - Recommended extensions configured"
    if [ "$VENV_EXISTS" = true ]; then
        echo "   - Virtual environment already exists"
    else
        echo "   - Virtual environment created"
    fi
    echo ""
    echo "💡 Tip:"
    echo "   - Ready to start coding!"
    echo '   - Use "uv run <script.py>" to run Python scripts'
    echo '   - Run "uv add <package-name>" when needed (e.g., uv add requests)'
fi

if [[ "$LANG_ENV" == "zh" ]]; then
    echo "🔌 推荐插件以获得更好体验:"
    echo "   - VS Code 用户: Ruff (charliermarsh.ruff) + Pylance (ms-python.vscode-pylance)"
    echo "   - Windsurf 用户: Ruff (charliermarsh.ruff) + Windsurf Pyright (内置)"
else
    echo "🔌 Recommended plugins for better experience:"
    echo "   - VS Code users: Ruff (charliermarsh.ruff) + Pylance (ms-python.vscode-pylance)"
    echo "   - Windsurf users: Ruff (charliermarsh.ruff) + Windsurf Pyright (built-in)"
fi
